{
  "name": "intervene",
  "version": "5.0.1",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "intervene": "dist/src/cli.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soundcloud/intervene.git"
  },
  "engines": {
    "node": ">=20.17.0",
    "npm": "11.13.0"
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc -p . -d && cp src/brotli-decode.* dist/src",
    "test": "npm run unit-test && npm run integration-test",
    "unit-test": "jest src",
    "integration-test": "jest integration-tests",
    "semantic-release": "semantic-release"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "dependencies": {
    "@hapi/hapi": "21.4.7",
    "@types/bluebird": "3.5.34",
    "@types/node": "18.19.130",
    "@types/node-forge": "0.8.7",
    "@types/prettier": "1.19.1",
    "@types/yargs": "12.0.20",
    "axios": "^0.21.2",
    "bluebird": "3.7.2",
    "chalk": "2.4.2",
    "eventsource": "1.1.2",
    "get-port": "4.2.0",
    "hostile": "1.4.0",
    "iconv-lite": "0.4.24",
    "joi": "17.13.3",
    "mkdirp": "1.0.4",
    "node-forge": "^0.10.0",
    "sudo-prompt": "8.2.5",
    "susie": "3.0.0",
    "ts-jest": "29.4.6",
    "ts-node": "8.10.2",
    "typescript": "4.9.5",
    "why-is-node-running": "2.3.0",
    "yargs": "12.0.5"
  },
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/npm": "13.1.5",
    "@types/jest": "29.5.14",
    "http-server": "0.12.3",
    "jest": "29.7.0",
    "lodash": "^4.17.21",
    "magicpen-media": "1.5.2",
    "mocha": "7.2.0",
    "prettier": "1.19.1",
    "semantic-release": "25.0.3",
    "sinon": "6.3.5",
    "unexpected": "10.40.2",
    "unexpected-sinon": "10.11.2"
  },
  "prettier": {
    "singleQuote": true,
    "arrowParens": "always"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/test-helpers/init.js"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "node"
    ],
    "testPathIgnorePatterns": [
      "/dist/",
      "/node_modules/",
      "/.cache/"
    ],
    "modulePathIgnorePatterns": [
      "/dist/",
      "/node_modules/",
      "/.cache/"
    ],
    "testMatch": [
      "<rootDir>/src/**/__tests__/*.spec.ts",
      "<rootDir>/integration-tests/**/*.spec.ts"
    ]
  }
}
